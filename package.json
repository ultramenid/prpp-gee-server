    "prod": "pm2 start ecosystem.config.js --env production",
    "prod:stop": "pm2 stop prpp-gee-server",
    "prod:restart": "pm2 restart prpp-gee-server",
    "prod:logs": "pm2 logs prpp-gee-server",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/earthengine": "^1.7.22",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "nodemonConfig": {
    "watch": [
      "api/"
    ],
    "ext": "js,json",
    "delay": 500,
    "ignore": [
      "node_modules/",
      ".env"
    ]
